# MongoDB Connection String
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/lp-draft-track?retryWrites=true&w=majority

# Payload CMS Secret (generate a random string)
PAYLOAD_SECRET=your-super-secret-key-here-use-openssl-rand-base64-32

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxx

# Next.js URL (for production, use your domain)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Job folder base paths (optional - only when running locally)
